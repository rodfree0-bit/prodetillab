rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- AUTHENTICATION HELPERS ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Fetch role from user document (CAUTION: Costs 1 read)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin');
    }
    
    function isWasher() {
      return isAuthenticated() && (getUserData().role == 'washer');
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isWasher() || isAdmin()); 
      allow create: if isAuthenticated() && request.auth.uid == userId && (
        !('role' in request.resource.data) || 
        request.resource.data.role == 'client' || 
        (request.resource.data.role == 'admin' && request.auth.token.email == 'rodfree0@gmail.com')
      ); 
      allow update: if isAdmin() || (isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
      ));
      allow delete: if isAdmin();
    }

    // --- TEAM COLLECTION ---
    match /team/{memberId} {
      allow read: if isAuthenticated(); 
      allow create: if isAdmin(); 
      allow update: if isAdmin() || (isOwner(memberId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
      )); 
      allow delete: if isAdmin();
    }

    // --- ORDERS COLLECTION (CRITICAL SECURITY) ---
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.washerId == request.auth.uid || 
        (isWasher() && resource.data.status == 'Pending') ||
        isAdmin()
      );
      
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.washerId == request.auth.uid ||
        (isWasher() && request.resource.data.washerId == request.auth.uid) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /settings/{document} {
      allow read: if true; 
      allow update: if isAuthenticated() && (isAdmin() || document == 'counters');
      allow create, delete: if isAdmin();
    }

    match /packages/{packageId} { allow read: if true; allow write: if isAdmin(); }
    match /addons/{addonId} { allow read: if true; allow write: if isAdmin(); }
    match /vehicle_types/{typeId} { allow read: if true; allow write: if isAdmin(); }
    match /serviceArea/{areaId} { allow read: if true; allow write: if isAdmin(); }
    match /seo_content/{document} { allow read: if true; allow write: if isAdmin(); }
    match /seo_daily_tips/{tipId} { allow read: if true; allow write: if isAdmin(); }
    match /approved_washers/{email} { allow read: if true; allow write: if isAdmin(); }

      // --- SUPPORT TICKETS (Secured Guest Access) ---
    match /supportTickets/{ticketId} {
      // Create is public for guests (Landing Page / Web Visitors). 
      // Read/Update restricted to the owner (via clientId/auth.uid) or Admin.
      // Note: guest_.* matches are publicly accessible to allow non-authenticated chat support.
      allow create: if true; 
      allow read: if (request.auth != null && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin())) || 
                     (resource.data.clientId.matches('guest_.*')); 
      allow update: if (request.auth != null && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin())) || 
                       (resource.data.clientId.matches('guest_.*'));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if (request.auth != null) || (get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.clientId.matches('guest_.*'));
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
      }
    }

    // --- INTERNAL MESSAGING (Strictly Auth Only) ---
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'washer-broadcast' || isAdmin());
      allow create: if isAuthenticated(); 
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- FINANCIALS (Admin Only / Washer Read Own) ---
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.washerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /payroll_periods/{periodId} {
      allow read: if isAuthenticated() && (isWasher() || isAdmin());
      allow write: if isAdmin();
    }

    // --- MISC / FORMS ---
    match /washer_applications/{applicationId} { 
      allow create: if true; // Publicly available for applicants
      allow read, update, delete: if isAdmin(); 
    }
    
    match /fleetQuotes/{quoteId} { 
      allow create: if true; // Publicly available for quotes
      allow read, update, delete: if isAdmin(); 
    }
    
    match /issues/{issueId} { 
      allow read, create, update: if isAuthenticated(); 
      allow delete: if isAdmin(); 
    }
    
    match /discounts/{discountId} { 
      allow read: if isAuthenticated(); 
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.clientId == request.auth.uid);
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount', 'active', 'usedBy']));
      allow delete: if isAdmin(); 
    }
    
    match /bonuses/{bonusId} { 
      allow read: if isAuthenticated() && (resource.data.washerId == request.auth.uid || isAdmin()); 
      allow write: if isAdmin(); 
    }

    match /deductions/{deductionId} {
      allow read: if isAuthenticated() && (resource.data.washerId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /social_config/{document} {
      allow read, write: if isAdmin();
    }

    match /pending_posts/{postId} {
      allow read, write: if isAdmin();
    }

    match /published_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
